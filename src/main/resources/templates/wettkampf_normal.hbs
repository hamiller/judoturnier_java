<!DOCTYPE html>
<html lang="de">
<head>
  {{> header}}
  <style>
    .btn.active {
      background-color: #007bff;
      color: white;
    }
  </style>
</head>
<body>
{{> title}}
{{> nav}}

<div>
  <div class="metainfos">
    <h1>Aktuelle Begegnung {{begegnungid}}</h1>
    <md-divider></md-divider>
    <div id="windowStatus">Kein Fenster geöffnet.</div>
    <md-filled-tonal-button type="button" id="open_timer" class="" onclick="openTimerWindow('{{begegnungid}}'); return false;">
      Wertungsbildschirm öffnen
    </md-filled-tonal-button>
  </div>
  <md-divider></md-divider>
  <form id="wertungen" action="/turnier/{{turnierid}}/begegnungen/normal/{{begegnungid}}" method="POST">
    <div class="ergebnis_flex">
      <div class="ergebnis_eintrag weiss half-width">
        <div class="wettkaempfer name">
          <label>
            <details>
              <summary>{{begegnung.wettkaempfer1.name}}</summary>
              ID: {{begegnung.wettkaempfer1.id}}
            </details>
          </label>
          <label class="WEISS">weiss</label>
          <label>{{begegnung.wettkaempfer1.verein.name}}</label>
        </div>
        <span class="row">
          <div class="weiss"><label>Ippon weiss:</label><input type="number" min="0" id="ippon_weiss" name="ippon_weiss" value="{{#optionalFn begegnung.kampfrichterWertung}}{{this.ipponWettkaempferWeiss}}{{/optionalFn}}" /><br/></div>
        </span>
        <span class="row">
          <div class="weiss"><label>Wazari weiss:</label><input type="number" min="0" id="wazari_weiss" name="wazari_weiss" value="{{#optionalFn begegnung.kampfrichterWertung}}{{this.wazariWettkaempferWeiss}}{{/optionalFn}}" /></div>
        </span>
        <span class="row">
          <div class="weiss"><label>Yuko weiss:</label><input type="number" min="0" id="yuko_weiss" name="yuko_weiss" value="{{#optionalFn begegnung.kampfrichterWertung}}{{this.yukoWettkaempferWeiss}}{{/optionalFn}}" /></div>
        </span>
        <span class="row">
          <div class="weiss">
            <label>Shido weiss:</label>
            <input type="hidden" id="shido_weiss" name="shido_weiss" value="{{#optionalFn begegnung.kampfrichterWertung}}{{this.shidoWettkaempferWeiss}}{{/optionalFn}}" />
            <label><input type="checkbox" class="shido_weiss" onchange="updateShido('weiss')" />1</label>
            <label><input type="checkbox" class="shido_weiss" onchange="updateShido('weiss')" />2</label>
            <label><input type="checkbox" class="shido_weiss" onchange="updateShido('weiss')" />3</label>
          </div>
        </span>
        <span class="row">
          <div class="weiss">
            <label>Hansoku Make weiss:</label>
            <input type="hidden" id="hansoku_make_weiss" name="hansoku_make_weiss" value="{{#if begegnung.kampfrichterWertung}}{{#optionalFn begegnung.kampfrichterWertung}}{{this.hansokuMakeWettkaempferWeiss}}{{/optionalFn}}{{else}}false{{/if}}" />
            <input type="checkbox" id="hansoku_make_weiss_checkbox" onchange="updateHansokuMake('weiss')" {{#optionalFn begegnung.kampfrichterWertung}}{{#if this.hansokuMakeWettkaempferWeiss}}checked{{/if}}{{/optionalFn}} />
          </div>
        </span>
      </div>
      <div class="ergebnis_eintrag blau half-width">
        <div class="wettkaempfer name blau">
          <label>
            <details>
              <summary>{{begegnung.wettkaempfer2.name}}</summary>
              ID: {{begegnung.wettkaempfer2.id}}
            </details>
          </label>
          <label class="BLAU">blau</label>
          <label>{{begegnung.wettkaempfer2.verein.name}}</label>
        </div>
        <span class="row">
          <div class="blau"><label>Ippon blau:</label><input type="number" min="0" id="ippon_blau" name="ippon_blau" value="{{#optionalFn begegnung.kampfrichterWertung}}{{this.ipponWettkaempferRot}}{{/optionalFn}}" /></div>
        </span>
        <span class="row">
          <div class="blau"><label>Wazari blau:</label><input type="number" min="0" id="wazari_blau" name="wazari_blau" value="{{#optionalFn begegnung.kampfrichterWertung}}{{this.wazariWettkaempferRot}}{{/optionalFn}}" /></div>
        </span>
        <span class="row">
          <div class="blau"><label>Yuko blau:</label><input type="number" min="0" id="yuko_blau" name="yuko_blau" value="{{#optionalFn begegnung.kampfrichterWertung}}{{this.yukoWettkaempferRot}}{{/optionalFn}}" /></div>
        </span>
        <span class="row">
          <div class="blau">
            <label>Shido blau:</label>
            <input type="hidden" id="shido_blau" name="shido_blau" value="{{#optionalFn begegnung.kampfrichterWertung}}{{this.shidoWettkaempferRot}}{{/optionalFn}}" />
            <label><input type="checkbox" class="shido_blau" onchange="updateShido('blau')" />1</label>
            <label><input type="checkbox" class="shido_blau" onchange="updateShido('blau')" />2</label>
            <label><input type="checkbox" class="shido_blau" onchange="updateShido('blau')" />3</label>
          </div>
        </span>
        <span class="row">
          <div class="blau">
            <label>Hansoku Make blau:</label>
            <input type="hidden" id="hansoku_make_blau" name="hansoku_make_blau" value="{{#if begegnung.kampfrichterWertung}}{{#optionalFn begegnung.kampfrichterWertung}}{{this.hansokuMakeWettkaempferRot}}{{/optionalFn}}{{else}}false{{/if}}" />
            <input type="checkbox" id="hansoku_make_blau_checkbox" onchange="updateHansokuMake('blau')" {{#optionalFn begegnung.kampfrichterWertung}}{{#if this.hansokuMakeWettkaempferRot}}checked{{/if}}{{/optionalFn}} />
          </div>
        </span>
      </div>
      <div class="ergebnis_eintrag full-width">
        <span class="row-centered">
          <label>Sieger:</label>
          <div class="element">
          <input type="radio" id="sieger_weiss" name="sieger" value="{{begegnung.wettkaempfer1.id}}" required {{#optionalFn begegnung.kampfrichterWertung}}{{setChecked this.sieger.id begegnung.wettkaempfer1.id}}{{/optionalFn}}>
          <label for="sieger_weiss">{{begegnung.wettkaempfer1.name}} - <span class="WEISS">weiss</span></label>
          </div>
          <div class="element">
          <input type="radio" id="sieger_blau" name="sieger" value="{{begegnung.wettkaempfer2.id}}" {{#optionalFn begegnung.kampfrichterWertung}}{{setChecked this.sieger.id begegnung.wettkaempfer2.id}}{{/optionalFn}}>
          <label for="sieger_blau">{{begegnung.wettkaempfer2.name}} - <span class="BLAU">blau</span></label>
          </div>
        </span>
        <input class="element" type="hidden" id="fightTime" name="fightTime" required value={{#optionalFn begegnung.kampfrichterWertung}}{{this.zeit}}{{/optionalFn}}
      </div>
      <div class="timer-container">
        <h1 id="timer-display" class="centered-horizontal"></h1>

        <div class="centered-horizontal">
          <md-filled-button type="button" class="" onclick="sendCommand('start', {{matteid}})">Starte Zeit</md-filled-button>
          <md-filled-button type="button" class="" onclick="sendCommand('stop', {{matteid}})">Stoppe Zeit</md-filled-button>
          <md-filled-button type="button" class="" onclick="sendCommand('reset', {{matteid}})">Zeit zurücksetzen</md-filled-button>
        </div>
      </div>
    </div>
  </form>
</div>

<div class="">
  <div class="nav_btn-container">
    <div class="">
      <md-filled-tonal-button type="button" id="nav_cancel" class="" href="/turnier/{{turnierid}}/begegnungen/normal">
        Abbrechen
        <svg slot="icon" height="18" viewBox="0 -960 960 960" width="18" fill="#5f6368">
          <path
            d="m336-280 144-144 144 144 56-56-144-144 144-144-56-56-144 144-144-144-56 56 144 144-144 144 56 56ZM480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/>
        </svg>
      </md-filled-tonal-button>
    </div>
    <div class="">
      {{#if enableEditing}}
        <md-filled-button type="button" id="nav_submit" class="" onclick="save(event);">
          Ergebnis speichern
          <svg slot="icon" height="18" viewBox="0 -960 720 720" width="18" fill="#5f6368">
            <path
              d="m 720,-800 v 480 q 0,33 -23.5,56.5 Q 673,-240 640,-240 H 80 Q 47,-240 23.5,-263.5 0,-287 0,-320 V -880 Q 0,-913 23.5,-936.5 47,-960 80,-960 h 480 z m -80,34 -114,-114 H 80 v 560 h 560 z m -280,406 q 50,0 85,-35 35,-35 35,-85 0,-50 -35,-85 -35,-35 -85,-35 -50,0 -85,35 -35,35 -35,85 0,50 35,85 35,35 85,35 z M 120,-680 H 480 V -840 H 120 Z m -40,-86 v 446 -560 z"/>
          </svg>
        </md-filled-button>
      {{/if}}
    </div>
  </div>
</div>

{{> footer}}

<script>
  const COUNTDOWN = {{kampfzeit}} * 1000; // Millisekunden

  let countdownTime = COUNTDOWN;
  let zeit = {{zeit begegnung}};
  if (zeit >= 0) {
    console.log("ZEIT:" , zeit);
    countdownTime = zeit;
  }
  let totalTime = 0;
  let interval = null;
  let timerDisplay = document.getElementById('timer-display');
  let fightTime = document.getElementById('fightTime');
  let socket = {};

  const formatTime = (milliseconds) => {
    const totalSeconds = Math.floor(Math.abs(milliseconds) / 1000);
    const minutes = Math.floor(totalSeconds / 60);
    const seconds = totalSeconds % 60;
    const ms = Math.abs(milliseconds % 1000) / 10;
    return `${minutes < 10 ? '0' : ''}${minutes}:${seconds < 10 ? '0' : ''}${seconds}.${ms < 10 ? '0' : ''}${Math.floor(ms)}`;
  }

  const updateTimer = () => {
    let time = formatTime(countdownTime);
    if (countdownTime >= 0) {
      timerDisplay.textContent = time;
    } else {
      timerDisplay.textContent = time;
      timerDisplay.classList.add('negative');
    }
    fightTime.value = time;
    countdownTime -= 10;
    totalTime += 10;
  }

  function start() {
    if (!interval) {
      interval = setInterval(updateTimer, 10);
    }
  }

  function stop() {
    clearInterval(interval);
    interval = null;
  }

  function reset() {
    stop();
    totalTime = 0;
    countdownTime = COUNTDOWN;
    updateTimer();
  }

  const sendCommand = (command, matte) => {
    console.log("Sende Command für Matte", command, matte)

    if (command == 'reset') {
      var sicher = confirm("ACHTUNG\n\nHiermit wird die Wettkampfzeit zurückgesetzt! \n\nSind sie sicher?");
      if (!sicher) return;
    }

    if (command === "start") start();
    if (command === "stop") stop();
    if (command === "reset") reset();

    if (socket && socket.readyState === WebSocket.OPEN) {
      socket.send(command);
    } else {
      const statusElement = document.getElementById("windowStatus");
      statusElement.innerText = "ACHTUNG: Kein Fenster geöffnet, Wertungen werden nur hier angezeigt!";
    }
  }

  const inputValue = (id) => {
    const input = document.getElementById(id);
    if (!input || input.value.trim() === "") {
      return "0";
    }
    return input.value;
  }

  const currentWertungMessage = () => ({
    type: "wertung",
    ippon_weiss: inputValue("ippon_weiss"),
    wazari_weiss: inputValue("wazari_weiss"),
    yuko_weiss: inputValue("yuko_weiss"),
    shido_weiss: inputValue("shido_weiss"),
    hansoku_make_weiss: document.getElementById("hansoku_make_weiss")?.value || "false",
    ippon_blau: inputValue("ippon_blau"),
    wazari_blau: inputValue("wazari_blau"),
    yuko_blau: inputValue("yuko_blau"),
    shido_blau: inputValue("shido_blau"),
    hansoku_make_blau: document.getElementById("hansoku_make_blau")?.value || "false"
  })

  const sendWertungUpdate = () => {
    if (socket && socket.readyState === WebSocket.OPEN) {
      socket.send(JSON.stringify(currentWertungMessage()));
    }
  }

  const openTimerWindow = (begegnungid) => {
    const matte = {{matteid}};
    const mattenRunde = {{mattenrunde}};
    // create new window
    console.log("Öffne Wertungsbildschirm für Begegnung", begegnungid)
    controlledWindow = window.open(
      '/turnier/{{turnierid}}/mattenanzeige/normal/' + begegnungid,
      'Matte ' + matte,
      'width=800,height=600,left=2000,top=0' // Passen Sie die Werte an Ihren zweiten Monitor an
    );
    controlledWindow.onbeforeunload = () => {
      controlledWindow = null;
    };

    // establish websocket
    const protocol = window.location.protocol === "https:" ? "wss" : "ws";
    const host = window.location.host; // z. B. "localhost:8080" oder "example.com"
    const path = "/mattenanzeigews?matte=" + matte; // Ihr WebSocket-Pfad
    const socketUrl = `${protocol}://${host}${path}`;
    socket = new WebSocket(socketUrl);

    socket.onopen = function () {
      console.log("Verbunden mit WebSocket, Matte ", matte);
      sendWertungUpdate();
    };

    socket.onclose = function () {
      console.log("WebSocket-Verbindung geschlossen, Matte ", matte);
      socket = null;
    };

    updateWindowStatus(matte, mattenRunde); // UI aktualisieren
  };

  const updateWindowStatus = (matte, mattenRunde) => {
    const statusElement = document.getElementById("windowStatus");
    if (controlledWindow && !controlledWindow.closed) {
      statusElement.innerText = "Geöffneter Wertungsbildschirm: Matte " + matte + ", Runde " + mattenRunde;
    } else {
      statusElement.innerText = "Kein Fenster geöffnet.";
    }
  }

  const validateForm = (event) => {
    var a1 = document.getElementById("ippon_weiss").value;
    var a2 = document.getElementById("wazari_weiss").value;
    var a3 = document.getElementById("yuko_weiss").value;
    var b1 = document.getElementById("ippon_blau").value;
    var b2 = document.getElementById("wazari_blau").value;
    var b3 = document.getElementById("yuko_blau").value;
    var c1 = document.getElementById("fightTime").value;
    var c2 = document.querySelector('input[name="sieger"]:checked');
    return (a1 != "/" && a2 != "/" && a3 != "/" && b1 != "/" && b2 != "/" && b3 != "/" && c1 != "/" && c2);
  }

  const defaultEmptyNumberFields = () => {
    ["ippon_weiss", "wazari_weiss", "yuko_weiss", "ippon_blau", "wazari_blau", "yuko_blau", "shido_weiss", "shido_blau"].forEach((id) => {
      const input = document.getElementById(id);
      if (input && input.value.trim() === "") {
        input.value = "0";
      }
    });
  }

  const setWinnerForHansokuMake = (farbe) => {
    const winner = farbe === "weiss" ? document.getElementById("sieger_blau") : document.getElementById("sieger_weiss");
    if (winner) {
      winner.checked = true;
    }
  }

  const updateHansokuMake = (farbe) => {
    const checkbox = document.getElementById("hansoku_make_" + farbe + "_checkbox");
    const input = document.getElementById("hansoku_make_" + farbe);
    if (!checkbox || !input) return;

    const shidoCount = parseInt(document.getElementById("shido_" + farbe)?.value || "0", 10) || 0;
    if (shidoCount >= 3 && !checkbox.checked) {
      checkbox.checked = true;
      checkbox.dataset.autoHansokuMake = "true";
      input.value = "true";
      setWinnerForHansokuMake(farbe);
      sendWertungUpdate();
      return;
    }

    checkbox.dataset.autoHansokuMake = "false";
    input.value = checkbox.checked ? "true" : "false";
    if (checkbox.checked) {
      setWinnerForHansokuMake(farbe);
    }
    sendWertungUpdate();
  }

  const updateShido = (farbe) => {
    const shidoBoxes = Array.from(document.querySelectorAll(".shido_" + farbe));
    const count = shidoBoxes.filter((checkbox) => checkbox.checked).length;
    const shidoInput = document.getElementById("shido_" + farbe);
    const hansokuMakeInput = document.getElementById("hansoku_make_" + farbe);
    const hansokuMakeCheckbox = document.getElementById("hansoku_make_" + farbe + "_checkbox");

    if (shidoInput) {
      shidoInput.value = String(count);
    }

    if (!hansokuMakeInput || !hansokuMakeCheckbox) return;

    if (count >= 3) {
      hansokuMakeCheckbox.checked = true;
      hansokuMakeCheckbox.dataset.autoHansokuMake = "true";
      hansokuMakeInput.value = "true";
      setWinnerForHansokuMake(farbe);
    } else if (hansokuMakeCheckbox.dataset.autoHansokuMake === "true") {
      hansokuMakeCheckbox.checked = false;
      hansokuMakeCheckbox.dataset.autoHansokuMake = "false";
      hansokuMakeInput.value = "false";
    }
    sendWertungUpdate();
  }

  const initializeShido = (farbe) => {
    const shidoInput = document.getElementById("shido_" + farbe);
    const shidoCount = Math.max(0, Math.min(3, parseInt(shidoInput?.value || "0", 10) || 0));
    const shidoBoxes = Array.from(document.querySelectorAll(".shido_" + farbe));
    shidoBoxes.forEach((checkbox, index) => {
      checkbox.checked = index < shidoCount;
    });
    updateShido(farbe);
  }

  const save = async (event) => {
    console.log("save event", event);
    var form = document.getElementById("wertungen");
    defaultEmptyNumberFields();
    var isValid = validateForm(event);
    if (isValid) {
      form.submit();
      return;
    }

    alert("Bitte alle Wertungen angeben.");
    event.preventDefault();
  };

  updateTimer();
  initializeShido("weiss");
  initializeShido("blau");
  ["ippon_weiss", "wazari_weiss", "yuko_weiss", "ippon_blau", "wazari_blau", "yuko_blau"].forEach((id) => {
    const input = document.getElementById(id);
    if (input) input.addEventListener("input", sendWertungUpdate);
  });
</script>
</body>
</html>
